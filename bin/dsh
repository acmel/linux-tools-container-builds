#!/bin/bash
# Arnaldo Carvalho de Melo <acme@redhat.com>, (C) 2016-
# Enter a container for looking for packages, try building a tool, etc.
# SPDX-License-Identifier: GPL-2.0-only

if [ "$1" = "." ] ; then
	image=$(grep "^# tools/" Dockerfile | cut -d'-' -f4-)
else
	image=$1
fi

shift

VMLINUX=$(pahole --running_kernel_vmlinux)
SECCOMP_CONFIG=$(type -p dm | sed -e 's/bin\/dm/config\/containers\/perf-seccomp.json/g')
podman run --cap-add=CAP_PERFMON -v $VMLINUX:/tmp/vmlinux:ro --security-opt seccomp=$SECCOMP_CONFIG $* --network host --tmpfs /tmp:size=8G --entrypoint=/bin/sh --rm -ti tools/linux-tools-build-${image}
